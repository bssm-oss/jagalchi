# Public client env. Copy to .env.local or .env.production and fill real values.
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_MOCKING=false
NEXT_PUBLIC_REALTIME_ENABLED=false
NEXT_PUBLIC_WS_URL=https://api.example.com/ws/roadmap
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_ENV=production

# Server-only Next.js env.
API_ORIGIN=https://api.example.com

# Optional feature flags.
NEXT_PUBLIC_AI_FEATURES_ENABLED=false
NEXT_PUBLIC_OAUTH_ENABLED=true
NEXT_PUBLIC_E2E_MOCKING=false

# Optional Sentry env.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
