# 개발 기본값은 실제 API 서버를 Next.js same-origin proxy(`/api`)로 연결한다.
# 브라우저 직접 호출(`https://api.jagalchi.dev`)은 백엔드 CORS 정책에 막히므로 사용하지 않는다.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_API_MOCKING=false
NEXT_PUBLIC_REALTIME_ENABLED=true
NEXT_PUBLIC_WS_URL=https://api.jagalchi.dev/ws/roadmap
NEXT_PUBLIC_SITE_URL=http://localhost:3000
API_ORIGIN=https://api.jagalchi.dev
