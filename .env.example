# Unified env template. Copy to .env.local or .env.production and fill real values.
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=jagalchi
MYSQL_USER=jagalchi
MYSQL_PASSWORD=change-me
MYSQL_HOST=mysql
MYSQL_PORT=3306
TZ=Asia/Seoul
SPRING_PROFILES_ACTIVE=prod

EXTERNAL_ROADMAP_BASE_URL=
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change-me
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USER=redis
REDIS_PASSWORD=

SECRET_KEY=change-me-at-least-32-bytes
JWT_SECRET=change-me-at-least-32-bytes
JAGALCHI_AUTH_JWT_SECRET=change-me
JAGALCHI_AUTH_TOKEN_USER_1_EDIT=
JAGALCHI_AUTH_TOKEN_USER_1_READ=

DB_URL=jdbc:mysql://jagalchi-mysql:3306/jagalchi?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=jagalchi
DB_PASSWORD=change-me
BASE_URL=http://localhost:8080
FRONT_URL=http://localhost:3000

EMAIL=your-email@example.com
GITHUB_CLIENT_ID=change-me
GITHUB_CLIENT_SECRET=change-me
GOOGLE_CLIENT_ID=change-me
GOOGLE_OAUTH_KEY=change-me
GOOGLE_PASSWORD=change-me

NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_MOCKING=false
NEXT_PUBLIC_REALTIME_ENABLED=false
NEXT_PUBLIC_WS_URL=https://api.example.com/ws/roadmap
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_ENV=production
API_ORIGIN=https://api.example.com
USER_SERVICE_URL=http://user.jagalchi.local:8081
NODE_SERVICE_URL=http://node.jagalchi.local:8082
NODE_WS_URL=ws://node.jagalchi.local:8082
