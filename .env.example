GEMINI_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=

# -----------------------------------------------------------------------------
# AI API Auth (JWT)
# -----------------------------------------------------------------------------
# - AI_AUTH_JWT_SECRET: HS256 서명/검증 시크릿 (운영에서는 반드시 강한 랜덤 값 사용)
# - 토큰은 `python manage.py issue_ai_token ...` 로 발급한 뒤 Authorization 헤더로 전송
AI_AUTH_ENABLED=true
AI_AUTH_JWT_SECRET=
# 개발 편의용(서버에서 직접 쓰진 않음): 발급한 토큰을 여기에 저장해두고 curl 등에서 사용
AI_AUTH_DEV_TOKEN_EDIT=
