# AI service env template. Copy to .env.local, .env.production, or .env.
DJANGO_SECRET_KEY=change-me-at-least-32-bytes
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000
AI_AUTH_ENABLED=true
AI_AUTH_JWT_SECRET=change-me
AI_AUTH_DEV_TOKEN_EDIT=
AI_DISABLE_LLM=false
AI_DISABLE_EXTERNAL=false
AI_DEFAULT_MODEL=gemini-2.5-flash
AI_TIMEOUT=30
AI_MAX_RETRIES=3
GEMINI_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=INFO
