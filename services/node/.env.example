# Node service env template. Copy to .env.local, .env.production, or .env for Spring dotenv loading.
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=jagalchi
MYSQL_USER=jagalchi
MYSQL_PASSWORD=change-me
MYSQL_HOST=mysql
MYSQL_PORT=3306
TZ=Asia/Seoul
SPRING_PROFILES_ACTIVE=docker
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/jagalchi?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul
SPRING_DATASOURCE_USERNAME=jagalchi
SPRING_DATASOURCE_PASSWORD=change-me
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change-me
REDIS_HOST=redis
REDIS_PORT=6379
